# ── MongoDB ───────────────────────────────────────────────────────────────────
# Get from MongoDB Atlas → Connect → Drivers → copy connection string
# Replace <password> with your Atlas password
MONGO_URI=mongodb+srv://prajwalaids24_db_user:<db_password>@cluster0.3vdnder.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=trading_journal

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-string

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=false
